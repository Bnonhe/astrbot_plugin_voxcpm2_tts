{
    "enabled": {
        "description": "插件总开关",
        "type": "bool",
        "hint": "VoxCPM2 TTS 插件总开关，请在部署好 VoxCPM2 Server 后再打开",
        "default": true
    },
    "server": {
        "description": "服务配置",
        "type": "object",
        "hint": "VoxCPM2 Server 的连接信息",
        "items": {
            "url": {
                "description": "VoxCPM2 服务地址",
                "type": "string",
                "hint": "VoxCPM2 Server 的完整地址",
                "default": "http://172.22.11.55:8000"
            },
            "api_key": {
                "description": "API Key",
                "type": "string",
                "hint": "VoxCPM2 Server 的 API Key，默认 voxcpm2",
                "default": "voxcpm2"
            },
            "timeout": {
                "description": "请求超时（秒）",
                "type": "int",
                "hint": "LoRA 推理较慢，建议 120s",
                "slider": { "min": 30, "max": 300, "step": 10 },
                "default": 120
            }
        }
    },
    "voice": {
        "description": "声音配置",
        "type": "object",
        "hint": "音色克隆和语言设置，参数组合决定合成模式",
        "items": {
            "voice_style": {
                "description": "声音风格描述",
                "type": "string",
                "hint": "如 warm female voice with slight British accent，留空则随机风格",
                "default": ""
            },
            "reference_wav_path": {
                "description": "参考音频路径",
                "type": "string",
                "hint": "用于音色克隆的参考音频，留空则不使用克隆",
                "default": ""
            },
            "prompt_text": {
                "description": "参考音频转录文本",
                "type": "string",
                "hint": "参考音频对应的文字内容，用于高保真克隆",
                "default": ""
            }
        }
    },
    "lora": {
        "description": "LoRA 配置（可选）",
        "type": "object",
        "hint": "LoRA 微调音色，留空 lora_path 则不使用",
        "items": {
            "lora_path": {
                "description": "LoRA 权重路径",
                "type": "string",
                "hint": "LoRA checkpoint 路径，留空则不使用 LoRA",
                "default": ""
            },
            "lora_alpha": {
                "description": "LoRA Alpha",
                "type": "float",
                "hint": "控制 LoRA 音色强度，需与训练时 r=32 匹配。alpha/r = 实际缩放",
                "slider": { "min": 1, "max": 64, "step": 1 },
                "default": 32
            }
        }
    },
    "generation": {
        "description": "生成参数",
        "type": "object",
        "hint": "控制语音合成的质量和格式",
        "items": {
            "cfg_value": {
                "description": "CFG 引导强度",
                "type": "float",
                "hint": "1.0=弱引导自然，2.0=默认，3.0=强引导严格遵循指令",
                "slider": { "min": 0.5, "max": 5.0, "step": 0.1 },
                "default": 2.0
            },
            "inference_timesteps": {
                "description": "推理步数",
                "type": "int",
                "hint": "4=快但糙，10=默认，30=慢但精",
                "slider": { "min": 4, "max": 30, "step": 1 },
                "default": 10
            },
            "output_format": {
                "description": "输出格式",
                "type": "string",
                "hint": "mp3 体积小，wav 无损",
                "options": ["mp3", "wav"],
                "default": "mp3"
            },
            "sample_rate": {
                "description": "采样率",
                "type": "int",
                "hint": "VoxCPM2 默认输出 48000Hz",
                "default": 48000
            }
        }
    },
    "auto_tts": {
        "description": "自动转语音",
        "type": "object",
        "hint": "LLM 回复后自动触发语音合成",
        "items": {
            "enable": {
                "description": "启用自动转语音",
                "type": "bool",
                "hint": "开启后，LLM 回复将自动合成语音",
                "default": true
            },
            "probability": {
                "description": "触发概率",
                "type": "float",
                "hint": "每次 LLM 回复触发语音合成的概率，1.0=每次都触发",
                "slider": { "min": 0, "max": 1, "step": 0.01 },
                "default": 1.0
            },
            "mode": {
                "description": "名单模式",
                "type": "string",
                "hint": "blacklist=全部启用但排除指定会话，whitelist=仅对指定会话启用",
                "options": ["blacklist", "whitelist"],
                "labels": ["黑名单（全部启用，排除指定）", "白名单（仅指定启用）"],
                "default": "blacklist"
            },
            "enabled_umos": {
                "description": "白名单 UMO",
                "type": "list",
                "hint": "whitelist 模式下生效的会话 ID，在聊天中发送 /sid 获取",
                "default": []
            },
            "disabled_umos": {
                "description": "黑名单 UMO",
                "type": "list",
                "hint": "blacklist 模式下排除的会话 ID，在聊天中发送 /sid 获取",
                "default": []
            }
        }
    },
    "text_output": {
        "description": "文字+语音同时输出",
        "type": "object",
        "hint": "控制是否同时发送文字和语音",
        "items": {
            "enable": {
                "description": "启用文字+语音同时输出",
                "type": "bool",
                "hint": "开启后同时发送文字和语音，否则只发语音",
                "default": false
            },
            "mode": {
                "description": "名单模式",
                "type": "string",
                "hint": "同自动转语音的名单模式",
                "options": ["blacklist", "whitelist"],
                "labels": ["黑名单（全部启用，排除指定）", "白名单（仅指定启用）"],
                "default": "whitelist"
            },
            "enabled_umos": {
                "description": "白名单 UMO",
                "type": "list",
                "hint": "",
                "default": []
            },
            "disabled_umos": {
                "description": "黑名单 UMO",
                "type": "list",
                "hint": "",
                "default": []
            }
        }
    },
    "text_filter": {
        "description": "文本过滤规则",
        "type": "object",
        "hint": "控制哪些文本会被合成语音",
        "items": {
            "max_length": {
                "description": "最大文本长度",
                "type": "int",
                "hint": "超过此长度的文本不会被合成语音",
                "slider": { "min": 50, "max": 2000, "step": 50 },
                "default": 500
            },
            "min_length": {
                "description": "最小文本长度",
                "type": "int",
                "hint": "短于此长度的文本不会被合成语音",
                "default": 2
            },
            "allow_mixed": {
                "description": "允许混合消息",
                "type": "bool",
                "hint": "含图片/引用等混合消息是否进入语音流程",
                "default": false
            },
            "cooldown": {
                "description": "冷却时间（秒）",
                "type": "int",
                "hint": "同一会话两次语音合成最小间隔秒数",
                "slider": { "min": 0, "max": 30, "step": 1 },
                "default": 3
            }
        }
    },
    "cache": {
        "description": "缓存配置",
        "type": "object",
        "hint": "语音缓存可减少重复推理",
        "items": {
            "enabled": {
                "description": "启用语音缓存",
                "type": "bool",
                "hint": "开启后，相同参数的请求直接复用缓存音频。LoRA 模式下自动禁用",
                "default": true
            },
            "expire_hours": {
                "description": "缓存过期时间（小时）",
                "type": "int",
                "hint": "0=永不过期，大于0按修改时间判断",
                "slider": { "min": 0, "max": 240, "step": 1 },
                "default": 0
            },
            "path": {
                "description": "缓存路径",
                "type": "string",
                "hint": "留空时默认 data/plugins_data/astrbot_plugin_voxcpm2_tts/audio",
                "default": ""
            }
        }
    }
}
